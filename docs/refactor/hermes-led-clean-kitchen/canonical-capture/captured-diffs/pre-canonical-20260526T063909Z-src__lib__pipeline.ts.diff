+export async function resetStalePipelineJobs(input: {
+  readonly staleAfterSeconds?: number;
+  readonly limit?: number;
+  readonly workerId?: string;
+} = {}): Promise<readonly PipelineJob[]> {
+  const staleAfterSeconds = Math.max(60, Math.floor(input.staleAfterSeconds ?? DEFAULT_STALE_JOB_SECONDS));
+  const limit = Math.max(1, Math.min(100, Math.floor(input.limit ?? 25)));
+  const resetBy = input.workerId ?? "pipeline-reaper";
+  const jobs = await query<PipelineJob>(
+    `WITH stale AS (
+       SELECT id
+       FROM pipeline_jobs
+       WHERE status = 'running'
+         AND COALESCE(heartbeat_at, locked_at, updated_at)
+           <= NOW() - ($1::int * INTERVAL '1 second')
+         AND attempts < max_attempts
+       ORDER BY COALESCE(heartbeat_at, locked_at, updated_at) ASC, id ASC
+       LIMIT $2
+       FOR UPDATE SKIP LOCKED
+     )
+     UPDATE pipeline_jobs
+     SET status = 'pending',
+         locked_by = NULL,
+         locked_at = NULL,
+         heartbeat_at = NULL,
+         error = 'Reset stale running job after heartbeat timeout',
+         updated_at = NOW()
+     FROM stale
+     WHERE pipeline_jobs.id = stale.id
+     RETURNING pipeline_jobs.*`,
+    [staleAfterSeconds, limit],
+  );
+
+  await Promise.all(jobs.map((job) => appendPipelineJobEvent({
+    runId: job.run_id,
+    jobId: job.id,
+    eventType: "stale_reset",
+    status: "pending",
+    message: "Reset stale running job",
+    payload: {
+      reset_by: resetBy,
+      stale_after_seconds: staleAfterSeconds,
+      previous_attempts: job.attempts,
+    },
+  })));
+
+  return jobs.map(normalizeJob);
 }
 
