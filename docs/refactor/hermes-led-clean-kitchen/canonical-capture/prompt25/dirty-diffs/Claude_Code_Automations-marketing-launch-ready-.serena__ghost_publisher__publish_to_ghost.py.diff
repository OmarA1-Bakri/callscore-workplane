-def extract_title_and_body(md_text: str, override_title: str | None = None) -> tuple[str, str]:
-    """Pull the first H1 as title, everything else as body. Override if provided."""
-    lines = md_text.splitlines()
-    title = override_title
-    body_start = 0
-    if title is None:
-        for idx, line in enumerate(lines):
-            stripped = line.strip()
-            if stripped.startswith("# ") and not stripped.startswith("## "):
-                title = stripped[2:].strip()
-                body_start = idx + 1
-                break
-    if title is None:
-        title = "Untitled"
-    body = "\n".join(lines[body_start:]).lstrip("\n")
-    return title, body
-
-
-def extract_excerpt(md_body: str, max_len: int = 280) -> str:
-    """First non-empty, non-heading, non-HR line, italics stripped."""
-    for line in md_body.splitlines():
-        s = line.strip()
-        if not s or s.startswith("#") or s.startswith("---") or s.startswith(">"):
-            continue
-        # strip italics/bold markers
-        s = re.sub(r"[*_]+", "", s)
-        if len(s) > max_len:
-            s = s[: max_len - 1].rstrip() + "…"
-        return s
-    return ""
-
-
-def md_to_html(md_body: str) -> str:
-    return markdown.markdown(
-        md_body,
-        extensions=["extra", "smarty", "sane_lists"],
-        output_format="html5",
-    )
-
