-def upload_image(api_url: str, admin_key: str, image_path: Path) -> str:
-    token = <REDACTED>
-    mime = mimetypes.guess_type(str(image_path))[0] or "image/png"
-    with image_path.open("rb") as f:
-        resp = requests.post(
-            f"{api_url.rstrip('/')}/ghost/api/admin/images/upload/",
-            headers={
-                "Authorization": f"Ghost {token}",
-                "Accept-Version": "v5.0",
-            },
-            files={"file": (image_path.name, f, mime)},
-            data={"purpose": "image", "ref": image_path.name},
-            timeout=60,
-        )
-    if not resp.ok:
-        raise RuntimeError(f"Image upload {resp.status_code}: {resp.text[:500]}")
-    return resp.json()["images"][0]["url"]
-
-
-def publish(
-    md_path: Path,
-    api_url: str,
-    admin_key: str,
-    status: str = "draft",
-    title_override: str | None = None,
-    tags: list[str] | None = None,
-    feature_image: Path | None = None,
-    feature_image_alt: str | None = None,
-    auto_image: bool = True,
-) -> dict:
-    md_text = md_path.read_text(encoding="utf-8")
-    title, body = extract_title_and_body(md_text, title_override)
-    excerpt = extract_excerpt(body)
-    html = md_to_html(body)
-
-    # Resolve feature image: explicit path > auto-detected sibling
-    if feature_image is None and auto_image:
-        found = find_companion_image(md_path)
-        if found is not None:
-            feature_image = found
-    feature_image_url = None
-    if feature_image is not None:
-        feature_image_url = upload_image(api_url, admin_key, feature_image)
-
-    token = <REDACTED>
-    endpoint = f"{api_url.rstrip('/')}/ghost/api/admin/posts/?source=html"
-
-    post_payload: dict = {
-        "title": title,
-        "html": html,
-        "status": status,
-    }
-    if excerpt:
-        post_payload["custom_excerpt"] = excerpt
-    if tags:
-        post_payload["tags"] = [{"name": t.strip()} for t in tags if t.strip()]
-    if feature_image_url:
-        post_payload["feature_image"] = feature_image_url
-        if feature_image_alt:
-            post_payload["feature_image_alt"] = feature_image_alt
-        elif title:
-            post_payload["feature_image_alt"] = title
-
-    resp = requests.post(
-        endpoint,
-        headers={
-            "Authorization": f"Ghost {token}",
-            "Content-Type": "application/json",
-            "Accept-Version": "v5.0",
-        },
-        json={"posts": [post_payload]},
-        timeout=30,
-    )
-
-    if not resp.ok:
-        raise RuntimeError(
-            f"Ghost API {resp.status_code}: {resp.text[:800]}"
-        )
-
-    data = resp.json()["posts"][0]
-    return {
-        "id": data.get("id"),
-        "title": data.get("title"),
-        "status": data.get("status"),
-        "url": data.get("url"),
-        "admin_edit_url": f"{api_url.rstrip('/')}/ghost/#/editor/post/{data.get('id')}",
-        "feature_image": data.get("feature_image"),
-    }
