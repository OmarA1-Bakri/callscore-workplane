-#!/usr/bin/env python3
-"""
-Ghost.io publisher — posts a markdown article to intelligentrails.news.
-
-Usage:
-    python publish_to_ghost.py <markdown_path> [--status draft|published] [--title "Override Title"] [--tags "tag1,tag2"]
-
-Credentials are read from environment variables:
-    GHOST_ADMIN_API_KEY   id:secret format (required for posting)
-    GHOST_API_URL         e.g. https://intelligent-rails-1.ghost.io
-    GHOST_CONTENT_API_KEY optional, used for read operations
-
-Defaults to status=draft. Use --status published to go live.
-"""
-
-from __future__ import annotations
-
-import argparse
-import mimetypes
-import os
-import re
-import sys
-import time
-from pathlib import Path
-
-import jwt
-import markdown
-import requests
-
-IMAGE_PATTERNS = ("*teaser*", "*hero*", "*cover*", "*feature*")
-IMAGE_EXTS = (".png", ".jpg", ".jpeg", ".webp")
-
-
-def build_jwt(admin_key: str) -> str:
-    key_id, secret = <REDACTED>":", 1)
-    iat = int(time.time())
-    payload = {"iat": iat, "exp": iat + 5 * 60, "aud": "/admin/"}
-    return jwt.encode(
-        payload,
-        bytes.fromhex(secret),
-        algorithm="HS256",
-        headers={"kid": key_id, "alg": "HS256", "typ": "JWT"},
