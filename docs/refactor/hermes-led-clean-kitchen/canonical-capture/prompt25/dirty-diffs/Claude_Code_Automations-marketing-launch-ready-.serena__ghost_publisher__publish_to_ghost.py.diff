-def find_companion_image(md_path: Path) -> Path | None:
-    """Look for a sibling hero/teaser/cover/feature image in the md file's directory.
-
-    Prefers files whose name starts with the md basename, falls back to any match.
-    """
-    folder = md_path.parent
-    if not folder.is_dir():
-        return None
-    basename = md_path.stem
-    candidates: list[Path] = []
-    for pattern in IMAGE_PATTERNS:
-        for p in folder.glob(pattern):
-            if p.suffix.lower() in IMAGE_EXTS and p.is_file():
-                candidates.append(p)
-    if not candidates:
-        return None
-    # Prefer ones that share the article's basename prefix
-    candidates.sort(key=lambda p: (not p.stem.lower().startswith(basename.lower()), p.name))
-    return candidates[0]
-
