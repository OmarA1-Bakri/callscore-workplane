@mcp.tool
def hh_run_srv_readonly(command: str, timeout_seconds: int = 45) -> dict[str, Any]:
    """Run a broader read-only shell command from /srv."""
    n = norm(command)
    if not n:
        return {"ok": False, "rejected": True, "reason": "empty command", "command": command}
    if any(sens in n for sens in SENSITIVE):
        return {"ok": False, "rejected": True, "reason": "sensitive target rejected", "command": command}
    blocked = [">", " rm ", " mv ", " chmod ", " chown ", " sudo ", " git commit", " git push", " docker compose up", " docker restart"]
    if any(x in f" {n} " for x in blocked):
        return {"ok": False, "rejected": True, "reason": "mutation-like command rejected", "command": command}
    return run(command, max(5, min(int(timeout_seconds), 120)))


def write_target_path(user_path: str) -> str:
    target = srv_path(user_path)
    reject_sensitive_path(target)
    if "/.git/" in target or target.endswith("/.git"):
        raise ValueError("refusing to write inside .git")
    return target


def backup_file(path: str) -> str | None:
    if not os.path.exists(path):
        return None
    stamp = time.strftime("%Y%m%dT%H%M%SZ", time.gmtime())
    backup = f"{path}.bak.{stamp}"
    shutil.copy2(path, backup)
    return backup


@mcp.tool
def hh_write_text_file(
    path: str,
    content: str,
    create_dirs: bool = True,
    backup_existing: bool = True,
) -> dict[str, Any]:
    """Write a text file under /srv, with optional parent creation and backup."""
    try:
        target = write_target_path(path)
        if os.path.isdir(target):
            return {"ok": False, "error": "target is a directory"}
        if len(content.encode("utf-8")) > 750_000:
            return {"ok": False, "error": "content too large"}
        if create_dirs:
            os.makedirs(os.path.dirname(target), exist_ok=True)
        backup = backup_file(target) if backup_existing else None
        with open(target, "w", encoding="utf-8") as f:
            f.write(content)
        return {"ok": True, "path": target, "bytes": os.path.getsize(target), "backup": backup}
    except Exception as exc:
        return {"ok": False, "error": str(exc)}


@mcp.tool
def hh_append_text_file(path: str, content: str) -> dict[str, Any]:
    """Append text to a file under /srv."""
    try:
        target = write_target_path(path)
        if len(content.encode("utf-8")) > 250_000:
            return {"ok": False, "error": "content too large"}
        os.makedirs(os.path.dirname(target), exist_ok=True)
        with open(target, "a", encoding="utf-8") as f:
            f.write(content)
        return {"ok": True, "path": target, "bytes": os.path.getsize(target)}
    except Exception as exc:
        return {"ok": False, "error": str(exc)}


@mcp.tool
def hh_replace_in_file(
    path: str,
    old_text: str,
    new_text: str,
    expected_replacements: int = 1,
) -> dict[str, Any]:
    """Replace text inside a file under /srv, with backup."""
    try:
        target = write_target_path(path)
        if not os.path.isfile(target):
            return {"ok": False, "error": "target is not a file"}
        data = open(target, "r", encoding="utf-8").read()
        count = data.count(old_text)
        if count == 0:
            return {"ok": False, "error": "old_text not found"}
        if expected_replacements > 0 and count != expected_replacements:
            return {"ok": False, "error": f"replacement count mismatch: found {count}"}
        backup = backup_file(target)
        data = data.replace(old_text, new_text)
        with open(target, "w", encoding="utf-8") as f:
            f.write(data)
        return {"ok": True, "path": target, "replacements": count, "backup": backup}
    except Exception as exc:
        return {"ok": False, "error": str(exc)}


@mcp.tool
def hh_make_directory(path: str) -> dict[str, Any]:
    """Create a directory under /srv."""
    try:
        target = write_target_path(path)
        os.makedirs(target, exist_ok=True)
        return {"ok": True, "path": target}
    except Exception as exc:
        return {"ok": False, "error": str(exc)}


@mcp.tool
def hh_operator_git_apply_patch(repo_path: str, patch_text: str) -> dict[str, Any]:
    """Apply a unified git patch inside a repo under /srv after git apply --check."""
    try:
        repo = srv_path(repo_path)
        reject_sensitive_path(repo)
        if not os.path.isdir(os.path.join(repo, ".git")):
            return {"ok": False, "error": "not a git repo"}
        if len(patch_text.encode("utf-8")) > 750_000:
            return {"ok": False, "error": "patch too large"}
        patch_file = f"/tmp/hh_patch_{int(time.time())}.diff"
        with open(patch_file, "w", encoding="utf-8") as f:
            f.write(patch_text)
        os.chmod(patch_file, 0o600)
        return run(
            f"cd {shlex.quote(repo)} && "
            f"git apply --check {shlex.quote(patch_file)} && "
            f"git apply {shlex.quote(patch_file)} && "
            "git status --short",
            60,
        )
    except Exception as exc:
        return {"ok": False, "error": str(exc)}


@mcp.tool
def hh_operator_docker_compose(project_path: str, action: str = "ps") -> dict[str, Any]:
    """Run selected docker compose actions inside a project under /srv."""
    try:
        project = srv_path(project_path)
        reject_sensitive_path(project)
        if not os.path.exists(os.path.join(project, "docker-compose.yml")) and not os.path.exists(os.path.join(project, "compose.yml")):
            return {"ok": False, "error": "no compose file found"}
        actions = {
            "ps": "docker compose ps",
            "build": "docker compose build",
            "up": "docker compose up -d",
            "up_build": "docker compose up -d --build",
            "restart": "docker compose restart",
            "logs": "docker compose logs --tail 160",
        }
        if action not in actions:
            return {"ok": False, "error": f"invalid action: {action}", "allowed": sorted(actions)}
        return run(f"cd {shlex.quote(project)} && {actions[action]}", 180)
    except Exception as exc:
        return {"ok": False, "error": str(exc)}


@mcp.tool
def hh_operator_run_repo_command(
    repo_path: str,
    command: str,
    timeout_seconds: int = 120,
) -> dict[str, Any]:
    """Run a bounded operator command inside a repo under /srv."""
    try:
        repo = srv_path(repo_path)
        reject_sensitive_path(repo)
        if not os.path.isdir(repo):
            return {"ok": False, "error": "repo_path is not a directory"}

        n = norm(command)
        blocked = (
            " rm ", " rmdir ", " shred ", " wipefs ", " mkfs", " dd ",
            " sudo ", " su ", " chmod ", " chown ", " chgrp ",
            " git push", " git commit", " git reset", " git clean",
            " netlify deploy", " netlify env:set", " tailscale funnel",
            " psql ", " prisma migrate deploy", " prisma migrate reset",
            " curl -x post", " curl -x put", " curl -x patch", " curl -x delete",
        )
        if any(x in f" {n} " for x in blocked):
            return {"ok": False, "error": "blocked operator command"}
        if any(x in n for x in SENSITIVE):
            return {"ok": False, "error": "sensitive command rejected"}

        allowed_prefixes = (
            "npm run", "pnpm run", "yarn run",
            "python3 -m", "python -m",
            "pytest", "ruff", "mypy", "npx", "node",
            "git status", "git diff", "git log",
            "docker compose ps", "docker compose logs", "docker compose build", "docker compose up -d",
        )
        if not any(n == p or n.startswith(p + " ") for p in allowed_prefixes):
            return {"ok": False, "error": "command prefix not allowed", "allowed_prefixes": allowed_prefixes}

        return run(f"cd {shlex.quote(repo)} && {command}", max(10, min(int(timeout_seconds), 300)))
    except Exception as exc:
        return {"ok": False, "error": str(exc)}


