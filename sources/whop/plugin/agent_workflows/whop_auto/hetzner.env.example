# Copy to .env.hetzner on the Hetzner VM and adjust paths if needed.
# Keep .env.hetzner out of git.

COMPOSE_PROJECT_NAME=whop-auto

# Match the Linux user that owns the VM runtime directories.
# Check on the VM with `id -u omar` and `id -g omar`.
WHOP_AUTO_UID=1000
WHOP_AUTO_GID=1001

# VM-owned runtime paths. These must live on Hetzner, not on the desktop.
WHOP_AUTO_STATE_DIR=/srv/whop-auto/state
WHOP_AUTO_WORKSPACE_DIR=/srv/whop-auto/workspace
WHOP_AUTO_SECRET_DIR=/srv/whop-auto/secrets
