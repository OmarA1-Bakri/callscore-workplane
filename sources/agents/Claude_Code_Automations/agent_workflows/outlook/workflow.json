      "enabled": true,
      "command_template": "python C:/Users/OmarAl-Bakri/Claude_Code_Automations/scripts/state_manager.py log-session --session-id \"outlook-triage-{{date}}-{{time}}\" --agent-name \"outlook_triage\" --skills-run \"inbox_triage\" --contacts-processed {{counts.total}} --interactions-logged {{counts.sent}} --follow-ups-created {{counts.follow_ups}} --summary \"{{summary}}\""
