  "format_rules": {
    "email_reply": {
      "platform": "outlook",
      "rules": [
        { "field": "text", "rule": "is_plain_text", "value": true, "on_fail": "auto_fix", "message": "Replies must be plain text" },
        { "field": "text", "rule": "max_chars", "value": 2000, "on_fail": "retry", "message": "Reply exceeds 2000 characters" },
        { "field": "text", "rule": "count_sentences", "value": { "max": 6 }, "on_fail": "warn", "message": "Reply should be under 6 sentences" },
        { "field": "text", "rule": "regex_match", "value": "(Omar|Best,\\s*Omar)\\s*$", "on_fail": "auto_fix", "message": "Must sign off as Omar" },
        { "field": "text", "rule": "no_prohibited_phrases", "value": ["I hope this email finds you well", "In today's", "It's worth noting", "leverage", "synergy", "paradigm shift", "landscape", "It's important to mention"], "on_fail": "retry", "message": "Contains AI/corporate slop" },
        { "field": "text", "rule": "no_prohibited_phrases", "value": ["Claude", "Anthropic", "OpenAI", "GPT", "AI assistant", "language model", "I'm an AI"], "on_fail": "abort", "message": "CRITICAL: Reveals AI involvement" }
      ]
    },
    "hot_prospect_reply": {
      "platform": "outlook",
      "rules": [
        { "field": "text", "rule": "count_sentences", "value": { "max": 4 }, "on_fail": "retry", "message": "HOT PROSPECT reply must be under 4 sentences" },
        { "field": "text", "rule": "regex_match", "value": "(call|meeting|chat|connect|walk you through)", "on_fail": "warn", "message": "HOT PROSPECT reply should propose a meeting" }
      ]
    },
    "warm_inbound_reply": {
      "platform": "outlook",
      "rules": [
        { "field": "text", "rule": "count_sentences", "value": { "max": 3 }, "on_fail": "retry", "message": "WARM INBOUND reply must be under 3 sentences" },
        { "field": "text", "rule": "regex_match", "value": "\\?", "on_fail": "warn", "message": "WARM INBOUND reply should include a qualifying question" }
      ]
    }
  },

  "error_handling": {
    "on_step_failure": "log_and_continue",
    "on_connection_failure": {
      "outlook": "abort_workflow",
      "gmail": "skip_dependent_steps",
      "telegram": "skip_dependent_steps"
    },
    "alert_config": {
      "channel": "telegram",
      "chat_id": "1778273779",
      "on_events": ["gate_failure", "rate_limit_breach", "workflow_abort"]
    },
    "max_consecutive_failures": 3
  },

  "post_completion": {
